{erl_opts, [debug_info]}.

{deps, []}.

%% Test configuration
{eunit_compile_opts, [debug_info]}.
%% Legacy PropEr suites are quarantined under test_legacy/proper and intentionally
%% kept out of the test profile because eunit_exclude_mods only affects
%% execution, not whether Rebar compiles modules on the test path.
{profiles, [
    {test, [
        {extra_src_dirs, [
            {"test", [{recursive, true}]}
        ]}
    ]}
]}.
{eunit_exclude_mods, [analyze_conflicts, location_tracking_demo, resource_limits_demo]}.

{plugins, []}.

%% Keep Yecc output beside the grammar, matching the direct build scripts.
{yrl_opts, [
    {parserfile, "src/compiler/parser/catena_parser"}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        underspecs,
        unknown
    ]},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [compiler, syntax_tools]},
    %% Exclude generated modules from analysis
    {exclude_mods, [
        catena_lexer,
        catena_parser
    ]}
]}.

{eunit_opts, [verbose]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% Coverage export configuration
{cover_export_enabled, true}.
{cover_excl_mods, [
    % Exclude generated modules from coverage
    catena_lexer,
    catena_parser
]}.
