-- Catena Testing Framework
-- Provides unit tests, property-based tests, and law verification
--
-- This replaces the 'test' and 'property' keywords with library functions.
-- Tests are first-class values that can be composed and organized.

module Test
export type Test
export type Property
export type PropertyConfig
export type PropertySpec
export type LawCheck
export type TestResult
export type Suite
export transform unit
export transform prop
export transform assert
export transform assertEqual
export transform assertMatch
export transform forAll
export transform implies
export transform discard
export transform defaultPropertyConfig
export transform withIterations
export transform withSeed
export transform withLabel
export transform verify
export transform verifyTrait
export transform verifyTraits
export transform withLawIterations
export transform withLawSeed
export transform suite
export transform suiteWithProperties
export transform run
export transform benchmark

import Prelude
import Gen

-- Test result types
type TestResult = Passed | Failed String | Skipped String

type Test = Test {
  name : String,
  run : Unit -> TestResult,
  lawCheck : Maybe LawCheck
}

-- Property bodies mirror the internal property-engine shape:
-- a zero-argument builder that will later evaluate to quantified property data.
type Property = Property {
  name : String,
  body : Unit -> PropertySpec,
  config : PropertyConfig
}

type PropertyConfig = PropertyConfig {
  iterations : Natural,
  seed : Maybe Natural,
  labels : List String
}

type PropertySpec =
  For_All Generator (Unit -> Unit)
  | Discard

type LawCheck = LawCheck {
  instanceName : String,
  traits : List String,
  config : PropertyConfig
}

type Suite = Suite {
  name : String,
  tests : List Test,
  properties : List Property
}

-- Create a unit test
-- Note: Type signatures and implementations must be combined due to parser limitation
transform unit name testFn = Test {
  name: name,
  run: fn u -> match (testFn u) of
    | true -> Passed
    | false -> Failed "Assertion failed"
  end,
  lawCheck: None
}

-- Create a property-based test
transform prop name body = Property {
  name: name,
  body: body,
  config: defaultPropertyConfig
}

transform forAll generator predicate = For_All generator predicate

transform implies condition predicate = match condition of
  | true -> predicate unit
  | false -> discard
end

transform discard = Discard

transform defaultPropertyConfig = PropertyConfig {
  iterations: 100,
  seed: None,
  labels: []
}

transform withIterations iterations propValue = Property {
  name: propValue.name,
  body: propValue.body,
  config: PropertyConfig {
    iterations: iterations,
    seed: propValue.config.seed,
    labels: propValue.config.labels
  }
}

transform withSeed seed propValue = Property {
  name: propValue.name,
  body: propValue.body,
  config: PropertyConfig {
    iterations: propValue.config.iterations,
    seed: Some seed,
    labels: propValue.config.labels
  }
}

transform withLabel label propValue = Property {
  name: propValue.name,
  body: propValue.body,
  config: PropertyConfig {
    iterations: propValue.config.iterations,
    seed: propValue.config.seed,
    labels: label :: propValue.config.labels
  }
}

-- Basic assertions
transform assert cond = match cond of
  | true -> Passed
  | false -> Failed "Assertion failed"
end

transform assertEqual expected actual = match (equals expected actual) of
  | true -> Passed
  | false -> Failed "Values not equal"
end

transform assertMatch pred value = match (pred value) of
  | true -> Passed
  | false -> Failed "Pattern match failed"
end

-- Verify that a type satisfies trait laws
transform verify lawName check = Test {
  name: lawName,
  run: fn u -> match (check u) of
    | true -> Passed
    | false -> Failed "Law verification failed"
  end,
  lawCheck: None
}

transform verifyTrait lawName instanceName traitName = verifyTraits lawName instanceName [traitName]

transform verifyTraits lawName instanceName traits = Test {
  name: lawName,
  run: fn u -> Passed,
  lawCheck: Some (LawCheck {
    instanceName: instanceName,
    traits: traits,
    config: defaultPropertyConfig
  })
}

transform withLawIterations iterations testValue = match testValue.lawCheck of
  | Some lawCheck -> Test {
      name: testValue.name,
      run: testValue.run,
      lawCheck: Some (LawCheck {
        instanceName: lawCheck.instanceName,
        traits: lawCheck.traits,
        config: PropertyConfig {
          iterations: iterations,
          seed: lawCheck.config.seed,
          labels: lawCheck.config.labels
        }
      })
    }
  | None -> testValue
end

transform withLawSeed seed testValue = match testValue.lawCheck of
  | Some lawCheck -> Test {
      name: testValue.name,
      run: testValue.run,
      lawCheck: Some (LawCheck {
        instanceName: lawCheck.instanceName,
        traits: lawCheck.traits,
        config: PropertyConfig {
          iterations: lawCheck.config.iterations,
          seed: Some seed,
          labels: lawCheck.config.labels
        }
      })
    }
  | None -> testValue
end

-- Create a test suite
transform suite name tests = Suite {
  name: name,
  tests: tests,
  properties: []
}

transform suiteWithProperties name tests properties = Suite {
  name: name,
  tests: tests,
  properties: properties
}

-- Run a test and get result
-- Note: () syntax not yet supported, using placeholder
transform run t = t.run unit

-- Benchmark type and function
type Benchmark = Benchmark {
  name : String,
  iterations : Natural,
  run : Unit -> Unit
}

transform benchmark name iterations benchFn = Benchmark {
  name: name,
  iterations: iterations,
  run: benchFn
}

-- Example usage:
--
-- myTests = suite "Math Tests" [
--   unit "addition" (fn () -> 1 + 1 === 2),
--   unit "multiplication" (fn () -> 2 * 3 === 6),
--   verify "Accumulator identity" (fn () ->
--     let empty = 0
--     let x = 5
--     combine empty x === x
--   )
-- ]
--
-- myProperty =
--   prop "addition commutative" (fn u ->
--     forAll Gen.int (fn n -> n >= 0)
--   )
--
-- tunedProperty =
--   withSeed 7 (withIterations 250 myProperty)
