-- Phase 14 algebraic-effects example.
-- This file uses the full higher-order handler model.

effect Resource
  operation withFile : String -> (Handle -> a / {IO}) -> a
end

transform firstLine path =
  perform Resource.withFile path (fn handle ->
    perform IO.readLine handle
  )

transform copyFirstLine source target =
  let line = firstLine source
  in perform IO.writeFile target line
