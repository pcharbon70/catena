-- Phase 14 algebraic-effects example.
-- This file uses the full handler/resumption model.

effect Error
  operation raise : String -> a
end

transform divide numerator denominator =
  match denominator
    | 0 -> perform Error.raise "division by zero"
    | _ -> numerator / denominator
  end

transform safeDivide numerator denominator =
  handle divide numerator denominator
    | Error.raise reason resume -> {error, reason}
    | return value -> {ok, value}
  end
