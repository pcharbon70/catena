-- Phase 14 algebraic-effects example.
-- This file stays close to the current parser-compatible core syntax.

effect Log
  operation info : String -> String
  operation warn : String -> String
end

transform emitStart =
  perform Log.info("starting pipeline")

transform emitWarning =
  perform Log.warn("slow path selected")

transform runLogging =
  handle (perform Log.info("starting pipeline")) then {
    Log {
      info(message) -> message
      warn(message) -> message
    }
  }
